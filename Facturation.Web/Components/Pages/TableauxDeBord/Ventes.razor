@page "/tableaudebord/ventes"
@rendermode InteractiveServer
@using Facturation.Services.Services
@using Radzen
@using Radzen.Blazor
@inject IAnalyseService AnalyseService

<PageTitle>Analyses Ventes - Delta Facturation</PageTitle>

<div class="page-header animate-in mb-4" style="padding:2rem 2rem 1.75rem;">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-graph-up-arrow me-2"></i>Tableau de Bord - Ventes
        </h3>
        <p class="mb-0 opacity-75">Suivi en temps réel des performances commerciales</p>
    </div>
</div>

<MudPaper Class="pa-4 mb-4" Elevation="1" Style="border-radius: 12px; background: #ffffff;">
    <div class="d-flex align-center gap-4 flex-wrap">
        <div style="min-width: 250px;">
            <MudDateRangePicker @bind-DateRange="dateRange" Label="Période de l'analyse" Variant="@MudBlazor.Variant.Outlined" DateFormat="dd/MM/yyyy" />
        </div>
        <MudButton Variant="@MudBlazor.Variant.Filled" Color="Color.Primary" OnClick="LoadData" StartIcon="@Icons.Material.Filled.Refresh" Class="py-3 px-6" Style="border-radius: 8px;">
            Actualiser
        </MudButton>
    </div>
</MudPaper>

@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height:300px;">
        <div class="text-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <p class="mt-3 text-muted fw-semibold">Génération des analyses de ventes...</p>
        </div>
    </div>
}
else if (dashboardData != null)
{
    <!-- KPIs Principaux -->
    <div class="row g-3 mb-4 animate-in">
        <div class="col-12 col-sm-6">
            <div class="stat-card stat-primary" style="background: linear-gradient(135deg, #1565C0 0%, #0D47A1 100%); color: white; border: none; min-height: 120px;">
                <div class="d-flex justify-content-between align-items-center h-100">
                    <div>
                        <div class="text-white-50 text-uppercase fw-semibold mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Chiffre d'Affaires HT</div>
                        <div class="stat-value text-white" style="font-size: 2rem;">@dashboardData.ChiffreAffairesTotalHT.ToString("N3") <span style="font-size: 1.1rem; font-weight: 500;">DT</span></div>
                    </div>
                    <div class="stat-icon" style="background: rgba(255,255,255,0.15); color: white;"><i class="bi bi-wallet2"></i></div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6">
            <div class="stat-card stat-accent" style="background: linear-gradient(135deg, #00BFA5 0%, #00897B 100%); color: white; border: none; min-height: 120px;">
                <div class="d-flex justify-content-between align-items-center h-100">
                    <div>
                        <div class="text-white-50 text-uppercase fw-semibold mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Chiffre d'Affaires TTC</div>
                        <div class="stat-value text-white" style="font-size: 2rem;">@dashboardData.ChiffreAffairesTotalTTC.ToString("N3") <span style="font-size: 1.1rem; font-weight: 500;">DT</span></div>
                    </div>
                    <div class="stat-icon" style="background: rgba(255,255,255,0.15); color: white;"><i class="bi bi-cash-coin"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Évolution du CA -->
        <div class="col-12 col-lg-8">
            <div class="card border-0" style="border-radius:12px; box-shadow:0 1px 3px rgba(0,0,0,.08); background: #ffffff;">
                <div class="card-header border-0 bg-transparent pt-3 px-4 pb-0">
                    <h6 class="fw-bold mb-0" style="font-family:'Poppins',sans-serif; color: var(--delta-text);">
                        <i class="bi bi-graph-up-arrow text-primary me-2"></i>Évolution Temporelle du CA (HT)
                    </h6>
                    <small class="text-muted">Variation par mois ou période sélectionnée</small>
                </div>
                <div class="card-body px-3 pt-2 pb-3" style="min-height: 330px;">
                    @if (evolutionData.Count > 0)
                    {
                        <RadzenChart Style="height: 300px; width: 100%;">
                            <RadzenAreaSeries Data="@evolutionData" CategoryProperty="Category" ValueProperty="Value" Title="CA HT (DT)" Smooth="true" Stroke="#1565C0" Fill="rgba(21, 101, 192, 0.12)">
                                <RadzenMarkers MarkerType="MarkerType.Circle" Size="4" Fill="#1565C0" />
                            </RadzenAreaSeries>
                            <RadzenCategoryAxis Padding="20" />
                            <RadzenValueAxis Formatter="@(value => $"{((double)value).ToString("N0")} DT")">
                                <RadzenGridLines Visible="true" StrokeWidth="1" Stroke="rgba(0,0,0,0.06)" />
                            </RadzenValueAxis>
                            <RadzenChartTooltipOptions Shared="true" />
                            <RadzenLegend Visible="false" />
                        </RadzenChart>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center h-100" style="min-height: 280px;">
                            <div class="text-center text-muted">
                                <i class="bi bi-calendar-x" style="font-size: 2.5rem;"></i>
                                <p class="mt-2">Aucune donnée pour cette période.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Top Clients -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 h-100" style="border-radius:12px; box-shadow:0 1px 3px rgba(0,0,0,.08); background: #ffffff; min-height: 330px;">
                <div class="card-header border-0 bg-transparent pt-3 px-4 pb-0">
                    <h6 class="fw-bold mb-0" style="font-family:'Poppins',sans-serif; color: var(--delta-text);">
                        <i class="bi bi-trophy-fill text-warning me-2"></i>Top Clients
                    </h6>
                    <small class="text-muted">Par volume d'achat HT</small>
                </div>
                <div class="card-body px-4 pb-3 pt-2" style="max-height: 320px; overflow-y: auto;">
                    @if (dashboardData.TopClients.Count > 0)
                    {
                        <table class="table table-hover table-sm align-middle mb-0" style="font-size:.85rem;">
                            <thead>
                                <tr>
                                    <th class="border-0 text-muted">Client</th>
                                    <th class="border-0 text-muted text-end">Total HT (DT)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var client in dashboardData.TopClients)
                                {
                                    <tr>
                                        <td class="py-2 fw-semibold" style="color: var(--delta-text);">@client.Nom</td>
                                        <td class="py-2 text-end fw-bold" style="color: var(--delta-primary);">@client.TotalAchatHT.ToString("N3")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center h-100 py-5">
                            <div class="text-center text-muted">
                                <i class="bi bi-people" style="font-size: 2rem;"></i>
                                <p class="mt-1 small">Aucun client trouvé.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Top Produits -->
        <div class="col-12 mt-3">
            <div class="card border-0" style="border-radius:12px; box-shadow:0 1px 3px rgba(0,0,0,.08); background: #ffffff;">
                <div class="card-header border-0 bg-transparent pt-3 px-4 pb-0">
                    <h6 class="fw-bold mb-0" style="font-family:'Poppins',sans-serif; color: var(--delta-text);">
                        <i class="bi bi-box-seam-fill text-success me-2"></i>Produits les plus vendus (Top 10)
                    </h6>
                    <small class="text-muted">Comparaison volume et valeur</small>
                </div>
                <div class="card-body px-4 pb-4 pt-2">
                    @if (dashboardData.TopProduits.Count > 0)
                    {
                        <div class="row g-3 align-items-center">
                            <div class="col-12 col-md-6">
                                <table class="table table-hover table-sm align-middle mb-0" style="font-size:.85rem;">
                                    <thead style="background: #F8FAFC;">
                                        <tr>
                                            <th class="py-2 text-muted">Produit</th>
                                            <th class="py-2 text-muted text-end">Quantité</th>
                                            <th class="py-2 text-muted text-end">Valeur HT</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var p in dashboardData.TopProduits)
                                        {
                                            <tr>
                                                <td class="py-2 fw-semibold" style="color: var(--delta-text);">@p.Libelle</td>
                                                <td class="py-2 text-end text-muted">@p.QuantiteVendue.ToString("N0")</td>
                                                <td class="py-2 text-end fw-bold" style="color: var(--delta-primary);">@p.ValeurTotaleHT.ToString("N3")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-12 col-md-6">
                                <RadzenChart Style="height: 280px; width: 100%;">
                                    <RadzenColumnSeries Data="@produitsData" CategoryProperty="Category" ValueProperty="Value" Title="Valeur HT" Fill="#00BFA5" />
                                    <RadzenCategoryAxis Padding="20" />
                                    <RadzenValueAxis Formatter="@(value => $"{((double)value).ToString("N0")} DT")">
                                        <RadzenGridLines Visible="true" StrokeWidth="1" Stroke="rgba(0,0,0,0.06)" />
                                    </RadzenValueAxis>
                                    <RadzenLegend Visible="false" />
                                </RadzenChart>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-box" style="font-size: 2.5rem; color:#CBD5E1;"></i>
                            <p class="text-muted mt-2">Aucun produit vendu dans cette période.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private VentesDashboardDto? dashboardData;
    private bool isLoading = true;
    private DateRange dateRange = new DateRange(new DateTime(DateTime.Today.Year, 1, 1), DateTime.Today);

    // Radzen Data points
    public class ChartDataItem
    {
        public string Category { get; set; } = string.Empty;
        public double Value { get; set; }
    }

    private List<ChartDataItem> evolutionData = new();
    private List<ChartDataItem> produitsData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        
        DateTime start = dateRange.Start ?? new DateTime(DateTime.Today.Year, 1, 1);
        DateTime end = dateRange.End ?? DateTime.Today;

        dashboardData = await AnalyseService.GetVentesDashboardDataAsync(start, end);

        // Prep CA Evolution
        if (dashboardData.CA_ParPeriode.Count > 0)
        {
            evolutionData = dashboardData.CA_ParPeriode.Select(kv => new ChartDataItem
            {
                Category = kv.Key,
                Value = (double)kv.Value
            }).ToList();
        }
        else
        {
            evolutionData.Clear();
        }

        // Prep Top Products Column Chart (take top 5 for neatness in chart)
        if (dashboardData.TopProduits.Count > 0)
        {
            produitsData = dashboardData.TopProduits.Take(5).Select(p => new ChartDataItem
            {
                Category = p.Libelle.Length > 12 ? p.Libelle[..12] + "…" : p.Libelle,
                Value = (double)p.ValeurTotaleHT
            }).ToList();
        }
        else
        {
            produitsData.Clear();
        }

        isLoading = false;
        StateHasChanged();
    }
}
