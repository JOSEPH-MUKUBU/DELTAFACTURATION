@inherits LayoutComponentBase

<MudThemeProvider Theme="_deltaTheme" />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

<div class="empty-layout-container">
    @Body
</div>

@code {
    private MudTheme _deltaTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1565C0",
            Secondary = "#00BFA5",
            Success = "#43A047",
            Warning = "#FB8C00",
            Error = "#E53935",
            Info = "#1565C0",
            Background = "#F0F2F5",
            Surface = "#FFFFFF",
            TextPrimary = "#1E293B",
            TextSecondary = "#64748B"
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "Inter", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" },
                FontSize = "0.9rem"
            },
            H3 = new H3Typography()
            {
                FontFamily = new[] { "Poppins", "Inter", "sans-serif" },
                FontWeight = "700",
                FontSize = "1.5rem"
            }
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "12px"
        }
    };
}
